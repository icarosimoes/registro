APP_NAME=Registro API
ENVIRONMENT=development
API_PREFIX=/api/v1
WEB_ORIGINS=http://localhost:3000

# MySQL legado: fonte de verdade durante a migração.
# Use caracteres escapados para URL quando necessário.
DATABASE_URL=mysql+asyncmy://aero:change-me@host.docker.internal:3306/aero?charset=utf8mb4
# Em produção Swarm, prefira DATABASE_URL_FILE=/run/secrets/registro_database_url.
DATABASE_ECHO=false
