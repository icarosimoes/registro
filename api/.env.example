APP_NAME=Registro API
ENVIRONMENT=development
API_PREFIX=/api/v1
WEB_ORIGINS=http://localhost:3000,http://localhost:3001

# MySQL novo de desenvolvimento. O dump legado será importado depois por processo controlado.
DATABASE_URL=mysql+asyncmy://registro:registro@mysql:3306/registro?charset=utf8mb4
# Em produção Swarm, prefira DATABASE_URL_FILE=/run/secrets/registro_database_url.
DATABASE_ECHO=false

# Gere uma chave longa e aleatória para cada ambiente.
JWT_SECRET=change-me-with-at-least-32-random-characters
# No Swarm: JWT_SECRET_FILE=/run/secrets/registro_jwt_secret
ACCESS_TOKEN_MINUTES=30

# Apenas seed local; forneça valores explícitos se executar o seed fora de development.
SEED_DEFAULT_PASSWORD=Registro@123
PLATFORM_ADMIN_PASSWORD=RegistroAdmin@123
